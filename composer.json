{
    "name": "yebto/device-analyzer-api",
    "description": "PHP SDK for the YEB Device Analyzer API. Parse user-agent strings to detect device, OS and browser.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "yeb",
        "api",
        "sdk",
        "laravel",
        "php",
        "device",
        "user-agent",
        "browser",
        "os"
    ],
    "homepage": "https://yeb.to",
    "support": {
        "email": "support@yeb.to",
        "issues": "https://github.com/yebto/device-analyzer-api/issues",
        "source": "https://github.com/yebto/device-analyzer-api"
    },
    "authors": [
        {
            "name": "NETOX Ltd.",
            "email": "support@yeb.to",
            "homepage": "https://yeb.to",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.1",
        "yebto/api-client": "^1.0"
    },
    "suggest": {
        "illuminate/support": "Required for Laravel Facade & ServiceProvider integration (^10.0|^11.0|^12.0)"
    },
    "autoload": {
        "psr-4": {
            "Yebto\\DeviceAnalyzerAPI\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Yebto\\DeviceAnalyzerAPI\\DeviceAnalyzerAPIServiceProvider"
            ],
            "aliases": {
                "DeviceAnalyzerAPI": "Yebto\\DeviceAnalyzerAPI\\Facades\\DeviceAnalyzerAPI"
            }
        }
    }
}
